                                            <button @click.stop="cancelInlineEdit" class="flex-1 h-[56px] rounded-2xl bg-slate-100 text-slate-600 font-black text-[16px] active:scale-95 transition-all">?оЎҪ?</button>
                                            <button @click.stop="saveInlineEdit" :disabled="saving" class="flex-1 h-[56px] rounded-2xl bg-[#FFB266] text-white font-black text-[19px] shadow-xl active:scale-95 transition-all">
                                                {{ saving ? 'з”Ү?оҜӯж‘®оҰ·?...' : 'иқЈз®„?йқҪж јоң–' }}
                                            </button>
