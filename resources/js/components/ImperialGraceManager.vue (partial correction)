        // Sync local form with data from child component
        form.value = { ...resolutionOrData };
    }
    
    let formMid = form.value.master_id ? String(form.value.master_id) : '';
    const folderId = currentFolder.value ? String(currentFolder.value.id) : '';

    // 核心判定：是否發生預期外的資料夾分流
    const isActuallyMismatched = folderId !== 'unobtained'
        ? (formMid !== folderId && folderId !== '')
        : (['已求得', '已登記'].includes(form.value.status));

    if (isActuallyMismatched && !resolution) {
        const mismatchMsg = currentFolder.value?.id === 'unobtained'
            ? `偵測到狀態已改為【${form.value.status}】，是否要將資料移回原屬仙師【${getMasterName(form.value.master_id)}】？`
            : `偵測到法寶將存入【${getMasterName(form.value.master_id)}】，但目前位於【${currentFolder.value.name}】，請問要存入哪一邊？`;
        
        persistentToast.value = { msg: mismatchMsg, type: 'mismatchConfirm' };
        return;
    }

    // 處理「改回原本資料夾」的邏輯 (存入目前所在位置)
