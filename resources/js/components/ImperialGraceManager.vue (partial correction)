    form.value = { 
        id: null, 
        master_id: defaultMasterId, 
        name: '', 
        purpose: '', 
        remarks: '', 
        record_date: new Date().toISOString().split('T')[0], 
        obtained_date: '', 
        status: '未求得' 
    };
